  myvocab:name """Alex Honnold free soloing "Freerider" """ ;
  myvocab:caption """Alex Honnold free soloing "Freerider" (5.13a, 30-pitches, 915-metres) on El Capitan, Yosemite, California""" ;
  myvocab:depicts <#alex_honnold> ;
