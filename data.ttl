  myvocab:name """Picture of the "Girl with a Pearl Earring" """ ;
  myvocab:caption "Megapixel Girl with a Pearl Earring by Johannes Vermeer" ;
  myvocab:location <#mauritshuis_the_hague> ;
  myvocab:photographer _:unknownPhotographer .

