@prefix myv: <http://www.example.com/myvData/>.
@prefix myvocab: <https://papichickens.github.io/vocab.ttl#> .
@prefix : <https://papichickens.github.io/data.ttl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Me identifier
<#me> a myvocab:Person;
  myvocab:ofAge "22"^^xsd:integer ;
  myvocab:fullName "Francisco Pimentel Alves" ;
  myvocab:firstName "Francisco" ;
  myvocab:lastName "Alves" ;
  myvocab:knows <#pieter_colpaert> , <#ben_de_meester> ;
  myvocab:hasHobby <#football> , <#guitar> ;
  myvocab:hasOccupation <#studentRole> ;
  # in regards to Prof. Pieter Colpaert's current comments around my punctuality :)
  myvocab:usuallyOnTime "true"^^xsd:boolean .

# University identifier
<#ugent> a myvocab:University ;
  myvocab:name "Ghent University" .

# Occupation indentifier
<#studentRole> a myvocab:StudentRole ;
  myvocab:name "student" ;
  myvocab:yearOfStudy "5"^^xsd:integer ;
  myvocab:studyingCourse <#course> ;
  myvocab:studiesAt <#ugent> .

<#professor> a myvocab:ProfessorRole ;
  myvocab:name "professor" ;
  myvocab:teachesCourse <#course> ;
  myvocab:teachesAt <#ugent> .

# Course Identifier
<#course> a myvocab:Course ;
  myvocab:name "Computer Science and Engineering" ;
  myvocab:courseLevel "Masters'" .
  
# Professors Identifier
<#pieter_colpaert> a myvocab:Person ;
  myvocab:fullName "prof. dr. Pieter Colpaert" ;
  myvocab:firstName "Pieter" ;
  myvocab:lastName "Colpaert" ;
  myvocab:email "pieter.colpaert@ugent.be" ;
  myvocab:hasOccupation <#professor> .

<#ben_de_meester> a myvocab:Person ;
  myvocab:fullName "dr. ir. Ben De Meester" ;
  myvocab:firstName "Ben" ;
  myvocab:lastName "de Meester" ;
  myvocab:email "ben.demeester@UGent.be" ;
  myvocab:hasOccupation <#professor> .

<#football> a myvocab:Hobby ;
  myvocab:name "Football" ;
  myvocab:comment "Watching and playing football" .

<#guitar> a myvocab:Hobby ;
  myvocab:name "Guitar" ;
  myvocab:comment "Playing guitar" .

# Photos

<#alex_honnold> a myvocab:Person ;
  myvocab:fullName "Alex J Honnold" ;
  myvocab:firstName "Alex" ;
  myvocab:lastName "Honnold" .

_:lucho_payne a myvocab:Person ;
  myvocab:firstName "Lucho" ;
  myvocab:lastName "Payne" .


<#fox_sports> a myvocab:Organization ;
  myvocab:name "Fox Sports" .

<#el_capitan_freerider> a myvocab:location ;
  myvocab:name "El Capitan (Freerider), Yosemite National Park, California" ;
  myvocab:latitude "37.73051"^^xsd:decimal ;
  myvocab:longitude "-119.63828"^^xsd:decimal .

<#mauritshuis_the_hague> a myvocab:location ;
  myvocab:name "Mauritshuis, The Hague, Netherlands" .

<#patershol_gent> a myvocab:location ;
  myvocab:name "Patershol, Gent, Belgium" .

<https://upload.wikimedia.org/wikipedia/commons/2/2d/First_Sporting_Clube_de_Portugal_Crest.jpg> a myvocab:Photograph ;
  myvocab:name "Photo of Francisco Alves" ;
  myvocab:caption "Photo of Francisco Alves" ;
  myvocab:location _:unknownLocation ;
  myvocab:depicts <#me> .
  
